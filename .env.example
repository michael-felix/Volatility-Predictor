# Copy this file to .env and fill in real values. Never commit .env.

# --- MongoDB ---
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=volatility_platform

# --- Data provider ---
DEFAULT_TICKERS=AAPL,MSFT,GOOGL,AMZN,TSLA
OHLCV_LOOKBACK_DAYS=730

# --- ML / model registry ---
MODEL_STORE_PATH=./models_store
MODEL_NAME=volatility_predictor
# filesystem (local dev/tests) or mongodb (production)
MODEL_REGISTRY_BACKEND=filesystem

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000
